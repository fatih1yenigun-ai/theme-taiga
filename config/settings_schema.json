        "info": "10 = 1.0, 13 = 1.3, 20 = 2.0"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "min": 0,
        "max": 30,
        "step": 1,
        "default": 0,
        "label": "Başlık harf aralığı",
        "info": "0-30 (10 = 1px)"
      },
      {
        "type": "header",
        "content": "Gövde metni"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "assistant_n4",
        "label": "Gövde fontu"
      },
      {
        "type": "text",
        "id": "custom_body_font_link",
        "label": "Özel gövde font bağlantısı"
      },
      {
        "type": "text",
        "id": "custom_body_font_name",
        "label": "Özel gövde font adı"
      },
      {
        "type": "range",
        "id": "custom_body_font_weight",
        "min": 300,
        "max": 1000,
        "step": 100,
        "default": 400,
        "label": "Gövde font kalınlığı"
      },
      {
        "type": "text",
        "id": "custom_body_bold_font_link",
        "label": "Özel gövde kalın font bağlantısı"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "default": 100,
        "unit": "%",
        "label": "Gövde boyut ölçeği"
      },
      {
        "type": "range",
        "id": "body_line_height",
        "min": 13,
        "max": 23,
        "step": 1,
        "default": 18,
        "label": "Gövde satır yüksekliği",
        "info": "13 = 1.3, 18 = 1.8, 23 = 2.3"
      },
      {
        "type": "range",
        "id": "body_letter_spacing",
        "min": 0,
        "max": 12,
        "step": 1,
        "default": 0,
        "label": "Gövde harf aralığı"
      },
      {
        "type": "header",
        "content": "Yazı yönü"
      },
      {
        "type": "checkbox",
        "id": "enable_rtl",
        "default": false,
        "label": "Sağdan sola yazımı etkinleştir (RTL)"
