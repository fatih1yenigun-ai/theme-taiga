  {
    "name": "Tipografi",
    "settings": [
      {
        "type": "header",
        "content": "Başlıklar"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "assistant_n7",
        "label": "Başlık fontu"
      },
      {
        "type": "text",
        "id": "custom_header_font_link",
        "label": "Özel başlık font bağlantısı",
