      {
        "type": "text",
        "id": "rtl_enabled_languages",
        "label": "RTL etkin diller",
        "info": "Virgülle ayırın: ar, he, fa"
      },
      {
        "type": "checkbox",
        "id": "display_store_languages",
        "label": "Eklenen mağaza dillerini ve kodlarını göster"
      }
