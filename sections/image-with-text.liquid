{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --section-heading-size: {{ section.settings.heading_size }}px;
    --section-image-width: {{ section.settings.image_width }}%;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    <div class="image-with-text__container image-with-text__container--{{ section.settings.desktop_layout }}">
      <div
        class="image-with-text__media"
        style="
          order: {% if section.settings.image_position == 'right' %}2{% else %}0{% endif %};
          flex-basis: var(--section-image-width);
          max-width: var(--section-image-width);
        "
      >
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="
              {{ section.settings.image | image_url: width: 600 }} 600w,
              {{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 749px) 100vw, {{ section.settings.image_width }}vw"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
            class="image-with-text__image"
          >
        {%- else -%}
          <div class="image-with-text__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="image-with-text__content" style="text-align: {{ section.settings.content_alignment }};">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <h2
                class="image-with-text__heading"
                style="
                  font-size: {{ block.settings.size }}px;
                  margin-top: {{ block.settings.margin_top }}px;
                  margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text | escape }}
              </h2>

            {%- when 'text' -%}
              <div
                class="image-with-text__text rte"
                style="
                  font-size: {{ block.settings.size }}px;
                  margin-top: {{ block.settings.margin_top }}px;
                  margin-bottom: {{ block.settings.margin_bottom }}px;
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>

            {%- when 'button' -%}
              {%- if block.settings.label != blank -%}
                <div
                  style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                  {{ block.shopify_attributes }}
                >
                  <a
                    href="{{ block.settings.link }}"
                    class="image-with-text__button button button--{{ block.settings.style }}"
                    {% if block.settings.link == blank %}aria-disabled="true"{% endif %}
                  >
                    {{ block.settings.label | escape }}
                  </a>
                </div>
              {%- endif -%}

            {%- when 'caption' -%}
              {%- if block.settings.text != blank -%}
                <p
                  class="image-with-text__caption"
                  style="
                    font-size: {{ block.settings.size }}px;
                    margin-top: {{ block.settings.margin_top }}px;
                    margin-bottom: {{ block.settings.margin_bottom }}px;
                  "
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text | escape }}
                </p>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .image-with-text__container {
    display: flex;
    gap: 48px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .image-with-text__container--overlap {
    gap: 0;
  }

  #shopify-section-{{ section.id }} .image-with-text__media {
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .image-with-text__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .image-with-text__placeholder {
    aspect-ratio: 4/3;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .image-with-text__placeholder svg {
    width: 60%;
    opacity: 0.3;
  }

  #shopify-section-{{ section.id }} .image-with-text__content {
    flex: 1;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .image-with-text__heading {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .image-with-text__text {
    color: rgb(var(--color-foreground));
    opacity: 0.75;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .image-with-text__caption {
    color: rgb(var(--color-foreground));
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .image-with-text__button {
    display: inline-block;
    padding: 14px 36px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .image-with-text__button.button--primary {
    background-color: var(--color-accent, #D4A843);
    color: #0a0a0a;
    border: none;
  }

  #shopify-section-{{ section.id }} .image-with-text__button.button--secondary {
    background: transparent;
    color: rgb(var(--color-foreground));
    border: 1px solid rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .image-with-text__button.button--link {
    background: transparent;
    color: var(--color-accent, #D4A843);
    border: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .image-with-text__button:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .image-with-text__button:focus-visible {
    outline: 2px solid var(--color-accent, #D4A843);
    outline-offset: 3px;
  }

  #shopify-section-{{ section.id }} .image-with-text__button:active {
    transform: translateY(0);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .image-with-text__container {
      flex-direction: column;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .image-with-text__media {
      flex-basis: 100% !important;
      max-width: 100% !important;
      order: 0 !important;
    }

    #shopify-section-{{ section.id }} .image-with-text__content {
      text-align: {{ section.settings.mobile_layout | default: 'center' }};
    }

    #shopify-section-{{ section.id }} .image-with-text__heading {
      font-size: calc(var(--section-heading-size) * 0.7) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Gorsel ve Metin",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Gorsel"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Gorsel Konumu",
      "options": [
        { "value": "left", "label": "Sol" },
        { "value": "right", "label": "Sag" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Gorsel Genisligi",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Baslik Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Masaustu Duzenleme",
      "options": [
        { "value": "standard", "label": "Standart" },
        { "value": "overlap", "label": "Bindirmeli" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobil Hizalama",
      "options": [
        { "value": "left", "label": "Sol" },
        { "value": "center", "label": "Orta" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Icerik Hizalama",
      "options": [
        { "value": "left", "label": "Sol" },
        { "value": "center", "label": "Orta" },
        { "value": "right", "label": "Sag" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Ust Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Baslik",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Baslik",
          "default": "Gorsel ve Metin"
        },
        {
          "type": "range",
          "id": "size",
          "label": "Boyut",
          "min": 18,
          "max": 60,
          "step": 2,
          "unit": "px",
          "default": 36
        },
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 16
        }
      ]
    },
    {
