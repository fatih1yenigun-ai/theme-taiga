      ]
    },
    {
      "type": "caption",
      "name": "Alt Yazi",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Alt Yazi",
          "default": "DOGAL ICERIK"
        },
        {
          "type": "range",
          "id": "size",
          "label": "Boyut",
          "min": 10,
          "max": 18,
          "step": 1,
          "unit": "px",
          "default": 12
        },
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 12
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gorsel ve Metin",
      "blocks": [
        { "type": "caption", "settings": { "text": "MARKAMIZ" } },
        { "type": "heading", "settings": { "text": "Dogal Bakim Cozumleri" } },
        { "type": "text", "settings": { "text": "<p>Urunlerimiz dogal iceriklerle zenginlestirilmis, cildinize ve saclariniza en iyi bakimi sunmak icin tasarlanmistir.</p>" } },
