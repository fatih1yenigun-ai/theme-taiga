        },
        {
          "type": "range",
          "id": "size",
          "label": "Boyut",
          "min": 12,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 20
        }
      ]
    },
    {
      "type": "button",
      "name": "Buton",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Buton Metni",
          "default": "Daha Fazla"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Baglanti"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Buton Stili",
          "options": [
            { "value": "primary", "label": "Birincil" },
            { "value": "secondary", "label": "Ikincil" },
            { "value": "link", "label": "Baglanti" }
