{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .blog-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 750px) {
    .blog-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
      gap: 32px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" style="background-color: #0a0a0a; color: #FFFFFF;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    <h1 style="margin: 0 0 32px 0; font-size: 2rem; font-weight: 700; color: #FFFFFF;">{{ blog.title }}</h1>

    {%- paginate blog.articles by 12 -%}
      <div class="blog-grid-{{ section.id }}">
        {%- for article in blog.articles -%}
          <article style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; transition: border-color 0.2s;">
            {%- if section.settings.show_image and article.image -%}
              <a href="{{ article.url }}" style="display: block; overflow: hidden;">
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  loading="lazy"
                  style="width: 100%; {% if section.settings.image_ratio == 'square' %}aspect-ratio: 1/1;{% elsif section.settings.image_ratio == 'portrait' %}aspect-ratio: 2/3;{% else %}aspect-ratio: 16/9;{% endif %} object-fit: cover; display: block; transition: transform 0.3s;"
                >
              </a>
            {%- endif -%}

            <div style="padding: 20px;">
              {%- if section.settings.show_date or section.settings.show_author -%}
                <div style="display: flex; gap: 12px; margin-bottom: 8px; font-size: 0.8rem; color: rgba(255,255,255,0.5);">
                  {%- if section.settings.show_date -%}
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%d.%m.%Y' }}</time>
                  {%- endif -%}
                  {%- if section.settings.show_author -%}
                    <span>{{ article.author }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <h2 style="margin: 0 0 8px 0; font-size: 1.15rem; font-weight: 600;">
                <a href="{{ article.url }}" style="color: #FFFFFF; text-decoration: none;">{{ article.title }}</a>
              </h2>

              {%- if section.settings.show_excerpt and article.excerpt_or_content != blank -%}
                <p style="margin: 0; font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.6);">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 25 }}
                </p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav style="display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 48px;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: #FFFFFF; text-decoration: none;">&laquo;</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: #FFFFFF; text-decoration: none;">{{ part.title }}</a>
            {%- else -%}
              <span style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: #FFFFFF; color: #0a0a0a; border-radius: 8px; font-weight: 600;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: #FFFFFF; text-decoration: none;">&raquo;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog Yazıları",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 3,
      "step": 1,
      "default": 3,
      "label": "Sütun sayısı"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Görseli göster"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Tarihi göster"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "Yazarı göster"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "Özeti göster"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "landscape", "label": "Yatay (16:9)" },
        { "value": "square", "label": "Kare (1:1)" },
        { "value": "portrait", "label": "Dikey (2:3)" }
      ],
      "default": "landscape",
      "label": "Görsel oranı"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "background-1",
        "options": [
          { "value": "background-1", "label": "Arka Plan 1" },
          { "value": "background-2", "label": "Arka Plan 2" },
          { "value": "accent-1", "label": "Vurgu 1" },
          { "value": "accent-2", "label": "Vurgu 2" },
          { "value": "inverse", "label": "Ters" },
          { "value": "custom", "label": "Özel" }
        ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Üst boşluk"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Alt boşluk"
    }
  ]
}
{% endschema %}
