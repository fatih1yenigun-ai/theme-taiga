{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .collections-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (min-width: 750px) {
    .collections-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
      gap: 24px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" style="background-color: #0a0a0a; color: #FFFFFF;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    <h1 style="margin: 0 0 32px 0; font-size: 2rem; font-weight: 700; color: #FFFFFF;">
      {{ section.settings.heading }}
    </h1>

    <div class="collections-grid-{{ section.id }}">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" style="display: block; text-decoration: none; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; transition: border-color 0.2s;">
          {%- if collection.image -%}
            <div style="overflow: hidden;">
              <img
                src="{{ collection.image | image_url: width: 800 }}"
                alt="{{ collection.image.alt | escape }}"
                loading="lazy"
                style="width: 100%; {% if section.settings.image_ratio == 'square' %}aspect-ratio: 1/1;{% elsif section.settings.image_ratio == 'portrait' %}aspect-ratio: 2/3;{% else %}aspect-ratio: 16/9;{% endif %} object-fit: cover; display: block; transition: transform 0.3s;"
              >
            </div>
          {%- else -%}
            <div style="{% if section.settings.image_ratio == 'square' %}aspect-ratio: 1/1;{% elsif section.settings.image_ratio == 'portrait' %}aspect-ratio: 2/3;{% else %}aspect-ratio: 16/9;{% endif %} background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
          {%- endif -%}

          <div style="padding: 16px;">
            <h2 style="margin: 0 0 4px 0; font-size: 1rem; font-weight: 600; color: #FFFFFF;">{{ collection.title }}</h2>
            <p style="margin: 0; font-size: 0.8rem; color: rgba(255,255,255,0.4);">{{ collection.products_count }} ürün</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Tüm Koleksiyonlar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Koleksiyonlar",
      "label": "Başlık"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Sütun sayısı"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "landscape", "label": "Yatay (16:9)" },
        { "value": "square", "label": "Kare (1:1)" },
        { "value": "portrait", "label": "Dikey (2:3)" }
      ],
      "default": "landscape",
      "label": "Görsel oranı"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "background-1",
        "options": [
          { "value": "background-1", "label": "Arka Plan 1" },
          { "value": "background-2", "label": "Arka Plan 2" },
          { "value": "accent-1", "label": "Vurgu 1" },
          { "value": "accent-2", "label": "Vurgu 2" },
          { "value": "inverse", "label": "Ters" },
          { "value": "custom", "label": "Özel" }
        ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Üst boşluk"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Alt boşluk"
    }
  ]
}
{% endschema %}
