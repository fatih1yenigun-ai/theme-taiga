{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --section-columns: {{ section.settings.columns }};
    --section-card-bg: {{ section.settings.card_bg }};
    --section-card-border: {{ section.settings.card_border }};
    --section-card-radius: {{ section.settings.card_radius }}px;
    --section-heading-size: {{ section.settings.heading_size }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="key-ingredients__header">
        <h2 class="key-ingredients__heading" style="font-size: var(--section-heading-size);">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.description != blank -%}
          <div class="key-ingredients__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="key-ingredients__grid" role="list">
        {%- for block in section.blocks -%}
          <article
            class="key-ingredients__card"
            style="
              margin-top: {{ block.settings.margin_top }}px;
              margin-bottom: {{ block.settings.margin_bottom }}px;
            "
            role="listitem"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="key-ingredients__image-wrapper" style="aspect-ratio: {{ section.settings.image_ratio }};">
                <img
                  class="key-ingredients__image"
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 300 }} 300w,
                    {{ block.settings.image | image_url: width: 600 }} 600w
                  "
                  sizes="(max-width: 749px) 50vw, calc(100vw / {{ section.settings.columns }})"
                  alt="{{ block.settings.name | escape }}"
                  width="600"
                  height="{{ 600 | divided_by: section.settings.image_ratio }}"
                  loading="lazy"
                >
              </div>
            {%- else -%}
              <div class="key-ingredients__image-placeholder" style="aspect-ratio: {{ section.settings.image_ratio }};">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="key-ingredients__content">
              {%- if block.settings.name != blank -%}
                <h3 class="key-ingredients__name">
                  {{ block.settings.name | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="key-ingredients__desc" style="font-size: {{ block.settings.text_size }}px;">
                  {{ block.settings.description | escape }}
                </p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .key-ingredients__header {
    text-align: center;
    margin-bottom: 48px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .key-ingredients__heading {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .key-ingredients__description {
    color: rgb(var(--color-foreground));
    opacity: 0.7;
    font-size: 16px;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .key-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(var(--section-columns, 3), 1fr);
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .key-ingredients__card {
    background-color: var(--section-card-bg, #1a1a1a);
    border: 1px solid var(--section-card-border, rgba(255,255,255,0.08));
    border-radius: var(--section-card-radius, 12px);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #shopify-section-{{ section.id }} .key-ingredients__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
  }

  #shopify-section-{{ section.id }} .key-ingredients__image-wrapper {
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .key-ingredients__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .key-ingredients__image-placeholder {
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .key-ingredients__image-placeholder svg {
    width: 60%;
    opacity: 0.3;
  }

  #shopify-section-{{ section.id }} .key-ingredients__content {
    padding: 20px;
  }

  #shopify-section-{{ section.id }} .key-ingredients__name {
    color: rgb(var(--color-foreground));
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  #shopify-section-{{ section.id }} .key-ingredients__desc {
    color: rgb(var(--color-foreground));
    opacity: 0.65;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .key-ingredients__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .key-ingredients__content {
      padding: 14px;
    }

    #shopify-section-{{ section.id }} .key-ingredients__name {
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Temel Icerikler",
  "tag": "section",
  "class": "section-key-ingredients",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Baslik",
      "default": "Temel Icerikler"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Baslik Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Aciklama",
      "default": "<p>Urunlerimizde kullanilan dogal ve etkili icerikler.</p>"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Sutun Sayisi",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "image_ratio",
      "label": "Gorsel Orani (ornek: 4/3)",
      "default": "4/3"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Kart Arka Plan",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Kart Cerceve Rengi",
      "default": "#262626"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Kart Kose Yuvarlama",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#141414",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Ust Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Icerik",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gorsel"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Icerik Adi",
          "default": "Deniz Tuzu"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Aciklama",
          "default": "Dogal mineraller iceren deniz tuzu, saca hacim ve doku kazandirmaya yardimci olur."
        },
        {
          "type": "range",
          "id": "text_size",
          "label": "Metin Boyutu",
          "min": 12,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Temel Icerikler",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Deniz Tuzu", "description": "Dogal mineraller iceren deniz tuzu, saca hacim ve doku kazandirmaya yardimci olur." } },
        { "type": "ingredient", "settings": { "name": "Argan Yagi", "description": "Besleyici argan yagi, saclari yumusatir ve parlatmaya yardimci olur." } },
        { "type": "ingredient", "settings": { "name": "Keratin", "description": "Keratin proteini, sacin dogal yapisini guclendirmeye yardimci olur." } }
      ]
    }
  ]
}
{% endschema %}
