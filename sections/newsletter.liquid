{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --section-heading-size: {{ section.settings.heading_size }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    <div class="newsletter__container newsletter__container--{{ section.settings.layout }}">
      {%- if section.settings.layout == 'side-by-side' and section.settings.image != blank -%}
        <div class="newsletter__image-col" style="order: {% if section.settings.image_position == 'right' %}2{% else %}0{% endif %};">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="
              {{ section.settings.image | image_url: width: 400 }} 400w,
              {{ section.settings.image | image_url: width: 800 }} 800w
            "
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.heading | escape }}"
            width="800"
            height="600"
            loading="lazy"
            class="newsletter__image"
          >
        </div>
      {%- endif -%}

      <div class="newsletter__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <h2
                class="newsletter__heading"
                style="font-size: var(--section-heading-size); margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                {{ block.shopify_attributes }}
              >
                {{ section.settings.heading | escape }}
              </h2>

            {%- when 'text' -%}
              {%- if section.settings.description != blank -%}
                <div
                  class="newsletter__text rte"
                  style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                  {{ block.shopify_attributes }}
                >
                  {{ section.settings.description }}
                </div>
              {%- endif -%}

            {%- when 'email_form' -%}
              <div
                class="newsletter__form-wrapper"
                style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                {{ block.shopify_attributes }}
              >
                {% form 'customer', class: 'newsletter__form' %}
                  <input type="hidden" name="contact[tags]" value="newsletter">

                  {%- if form.errors -%}
                    <div class="newsletter__message newsletter__message--error" role="alert">
                      {{ form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email }}
                    </div>
                  {%- endif -%}

                  {%- if form.posted_successfully? -%}
                    <div class="newsletter__message newsletter__message--success" role="status">
                      {{ 'newsletter.success' | t }}
                    </div>
                  {%- endif -%}

                  <div class="newsletter__input-group">
                    <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <input
                      type="email"
                      name="contact[email]"
                      id="newsletter-email-{{ section.id }}"
                      class="newsletter__input"
                      placeholder="E-posta adresiniz"
                      required
                      autocomplete="email"
                      aria-required="true"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="newsletter-error-{{ section.id }}"
                      {% endif %}
                    >
                    <button
                      type="submit"
                      class="newsletter__button button button--{{ section.settings.button_style }}"
                      aria-label="{{ section.settings.button_text | escape }}"
                    >
                      {{ section.settings.button_text | escape }}
                    </button>
                  </div>
                {% endform %}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .newsletter__container {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .newsletter__container--side-by-side {
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .newsletter__image-col {
    overflow: hidden;
    border-radius: 12px;
  }

  #shopify-section-{{ section.id }} .newsletter__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .newsletter__heading {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .newsletter__text {
    color: rgb(var(--color-foreground));
    opacity: 0.7;
    font-size: 16px;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .newsletter__form {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .newsletter__input-group {
    display: flex;
    gap: 0;
    max-width: 500px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .newsletter__container--side-by-side .newsletter__input-group {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .newsletter__input {
    flex: 1;
    padding: 14px 20px;
    border: 1px solid rgba(255,255,255,0.15);
    border-right: none;
    border-radius: 8px 0 0 8px;
    background: rgba(255,255,255,0.05);
    color: rgb(var(--color-foreground));
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .newsletter__input::placeholder {
    color: rgb(var(--color-foreground));
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .newsletter__input:focus {
    border-color: var(--color-accent, #D4A843);
  }

  #shopify-section-{{ section.id }} .newsletter__button {
    padding: 14px 28px;
    border: none;
    border-radius: 0 8px 8px 0;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .newsletter__button.button--primary {
    background-color: var(--color-accent, #D4A843);
    color: #0a0a0a;
  }

  #shopify-section-{{ section.id }} .newsletter__button.button--secondary {
    background-color: transparent;
    border: 1px solid rgb(var(--color-foreground));
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .newsletter__button:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .newsletter__button:focus-visible {
    outline: 2px solid var(--color-accent, #D4A843);
    outline-offset: 2px;
  }

  #shopify-section-{{ section.id }} .newsletter__button:active {
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .newsletter__message {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .newsletter__message--error {
    background: rgba(220, 38, 38, 0.15);
    color: #fca5a5;
    border: 1px solid rgba(220, 38, 38, 0.3);
  }

  #shopify-section-{{ section.id }} .newsletter__message--success {
    background: rgba(34, 197, 94, 0.15);
    color: #86efac;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  #shopify-section-{{ section.id }} .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .newsletter__container--side-by-side {
      grid-template-columns: 1fr;
      gap: 24px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .newsletter__input-group {
      flex-direction: column;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .newsletter__input {
      border-right: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
    }

    #shopify-section-{{ section.id }} .newsletter__button {
      border-radius: 8px;
    }

    #shopify-section-{{ section.id }} .newsletter__heading {
      font-size: calc(var(--section-heading-size) * 0.7) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Bulten Kaydi",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Baslik",
      "default": "Bultenimize Abone Olun"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Baslik Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Aciklama",
      "default": "<p>Yeni urunler, ozel kampanyalar ve bakim ipuclari icin e-posta listemize katilmak ister misiniz?</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Buton Metni",
      "default": "Abone Ol"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Buton Stili",
      "options": [
        { "value": "primary", "label": "Birincil" },
        { "value": "secondary", "label": "Ikincil" }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Duzenleme",
      "options": [
        { "value": "stacked", "label": "Ust Uste" },
        { "value": "side-by-side", "label": "Yan Yana" }
      ],
      "default": "stacked"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Gorsel (Yan Yana duzende)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Gorsel Konumu",
      "options": [
        { "value": "left", "label": "Sol" },
        { "value": "right", "label": "Sag" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#141414",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Ust Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Baslik",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 12
        }
      ]
    },
    {
      "type": "text",
      "name": "Metin",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 20
        }
      ]
    },
    {
      "type": "email_form",
      "name": "E-posta Formu",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "margin_top",
          "label": "Ust Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Alt Kenar Boslugu",
          "min": 0,
          "max": 30,
          "step": 2,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bulten Kaydi",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "email_form" }
      ]
    }
  ]
}
{% endschema %}
