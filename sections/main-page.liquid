{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" style="background-color: #0a0a0a; color: #FFFFFF;">
  <div style="max-width: {% if section.settings.narrow_width %}740px{% else %}1200px{% endif %}; margin: 0 auto; padding: 0 20px;">
    <{{ section.settings.heading_size }} style="margin: 0 0 24px 0; font-weight: 700; color: #FFFFFF;">
      {{ page.title }}
    </{{ section.settings.heading_size }}>

    <div class="rte" style="color: rgba(255,255,255,0.85); line-height: 1.7; font-size: 1rem;">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sayfa İçeriği",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "narrow_width",
      "default": true,
      "label": "Dar genişlik (740px)"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1",
      "label": "Başlık boyutu"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Üst boşluk"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Alt boşluk"
    }
  ]
}
{% endschema %}
