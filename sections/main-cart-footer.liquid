{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" style="background-color: #0a0a0a; color: #FFFFFF;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    {%- if cart.item_count > 0 -%}
      <div style="max-width: 480px; margin-left: auto;">
        {%- if section.settings.show_notes -%}
          <div style="margin-bottom: 24px;">
            <label for="cart-note" style="display: block; margin-bottom: 6px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">
              {{ section.settings.notes_label }}
            </label>
            <textarea
              id="cart-note"
              name="note"
              form="cart"
              rows="3"
              style="width: 100%; padding: 10px 14px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #FFFFFF; font-size: 0.9rem; outline: none; resize: vertical; box-sizing: border-box;"
            >{{ cart.note }}</textarea>
          </div>
        {%- endif -%}

        <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <span style="font-size: 1rem; color: rgba(255,255,255,0.7);">Ara Toplam</span>
            <span style="font-size: 1.25rem; font-weight: 700; color: #FFFFFF;">{{ cart.total_price | money }}</span>
          </div>

          <p style="margin: 0 0 20px 0; font-size: 0.8rem; color: rgba(255,255,255,0.4);">
            Kargo ve vergiler ödeme sırasında hesaplanır.
          </p>

          <div style="display: flex; flex-direction: column; gap: 10px;">
            <button
              type="submit"
              name="checkout"
              form="cart"
              style="width: 100%; padding: 16px; background: #FFFFFF; color: #0a0a0a; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s;"
            >
              {{ section.settings.checkout_text }}
            </button>

            <a
              href="{{ routes.all_products_collection_url }}"
              style="display: block; width: 100%; padding: 14px; text-align: center; background: transparent; color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: border-color 0.2s; box-sizing: border-box;"
            >
              {{ section.settings.continue_text }}
            </a>
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Sepet Altbilgi",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_notes",
      "default": true,
      "label": "Sipariş notu göster"
    },
    {
      "type": "text",
      "id": "notes_label",
      "default": "Sipariş Notu",
      "label": "Not etiketi"
    },
    {
      "type": "text",
      "id": "checkout_text",
      "default": "Ödemeye Geç",
      "label": "Ödeme butonu metni"
    },
    {
      "type": "text",
      "id": "continue_text",
      "default": "Alışverişe Devam Et",
      "label": "Devam butonu metni"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "background-1",
        "options": [
          { "value": "background-1", "label": "Arka Plan 1" },
          { "value": "background-2", "label": "Arka Plan 2" },
          { "value": "accent-1", "label": "Vurgu 1" },
          { "value": "accent-2", "label": "Vurgu 2" },
          { "value": "inverse", "label": "Ters" },
          { "value": "custom", "label": "Özel" }
        ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 24,
      "unit": "px",
      "label": "Üst boşluk"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Alt boşluk"
    }
  ]
}
{% endschema %}
