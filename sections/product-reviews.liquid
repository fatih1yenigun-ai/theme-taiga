{%- style -%}
  .reviews-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }};
    --padding-bottom: {{ section.settings.padding_bottom }};
  }
{%- endstyle -%}

{%- assign total_reviews = 0 -%}
{%- assign total_rating = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'review' -%}
    {%- assign total_reviews = total_reviews | plus: 1 -%}
    {%- assign total_rating = total_rating | plus: block.settings.rating -%}
  {%- endif -%}
{%- endfor -%}

<section class="reviews-section reviews-{{ section.id }} section-padding color-{{ section.settings.color_scheme }}" style="background: {{ section.settings.bg_color }};">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="{{ section.settings.heading_size }}" style="text-align: {{ section.settings.heading_alignment }}; color: {{ section.settings.heading_color }}; margin-bottom: 3.2rem;">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.show_summary and total_reviews > 0 -%}
      {%- assign avg_x10 = total_rating | times: 10 | divided_by: total_reviews -%}
      {%- assign avg_whole = avg_x10 | divided_by: 10 -%}
      {%- assign avg_dec = avg_x10 | modulo: 10 -%}
      <div class="reviews-summary text-center" style="margin-bottom: 3.2rem;">
        <div style="font-size: {{ section.settings.avg_size | divided_by: 10.0 }}rem; font-weight: 900; color: {{ section.settings.star_color }};">
          {{ avg_whole }}.{{ avg_dec }}
        </div>
        <div style="color: {{ section.settings.star_color }}; font-size: 2rem; margin: 0.4rem 0;">
          {%- for i in (1..5) -%}{% if i <= avg_whole %}★{% else %}☆{% endif %}{%- endfor -%}
        </div>
        <div class="text-muted" style="font-size: {{ section.settings.count_size | divided_by: 10.0 }}rem;">
          {{ total_reviews }} {{ section.settings.count_text }}
        </div>
      </div>
    {%- endif -%}

    <div class="reviews-grid" style="display: grid; grid-template-columns: repeat({{ section.settings.columns }}, 1fr); gap: {{ section.settings.card_gap }}px; max-width: {{ section.settings.max_width }}px; margin: 0 auto;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="review-card" style="background: {{ section.settings.card_bg }}; border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }}; border-radius: {{ section.settings.card_radius }}px; padding: {{ section.settings.card_padding }}px; box-shadow: {{ section.settings.card_shadow_x }}px {{ section.settings.card_shadow_y }}px {{ section.settings.card_shadow_blur }}px rgba(0,0,0,{{ section.settings.card_shadow_opacity | divided_by: 100.0 }});" {{ block.shopify_attributes }}>
            <div style="color: {{ section.settings.star_color }}; font-size: {{ section.settings.review_star_size | divided_by: 10.0 }}rem; margin-bottom: 0.8rem;">
              {%- for i in (1..5) -%}{% if i <= block.settings.rating %}★{% else %}☆{% endif %}{%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <div style="font-size: {{ section.settings.review_title_size | divided_by: 10.0 }}rem; font-weight: 700; margin-bottom: 0.6rem; color: {{ section.settings.review_title_color }};">
                {{ block.settings.title }}
              </div>
            {%- endif -%}
            <div style="font-size: {{ section.settings.review_body_size | divided_by: 10.0 }}rem; color: {{ section.settings.review_body_color }}; line-height: 1.7; margin-bottom: 1.2rem;">
              {{ block.settings.body }}
            </div>
            <div style="font-size: {{ section.settings.review_author_size | divided_by: 10.0 }}rem; color: {{ section.settings.review_author_color }};">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 64 }}" alt="{{ block.settings.author }}" style="width: 2.4rem; height: 2.4rem; border-radius: 50%; display: inline-block; vertical-align: middle; margin-right: 0.6rem; object-fit: cover;" loading="lazy">
              {%- endif -%}
              {{ block.settings.author }}
              {%- if block.settings.date != blank %} · {{ block.settings.date }}{% endif -%}
              {%- if block.settings.verified -%}
                <span style="color: #4CAF50; font-size: 1.1rem; font-weight: 600; margin-left: 0.4rem;">✓ {{ section.settings.verified_text }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ürün Değerlendirmeleri",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Başlık"
