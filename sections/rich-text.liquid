{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --section-heading-size: {{ section.settings.heading_size }}px;
    --section-text-width: {{ section.settings.text_width }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    <div
      class="rich-text__container"
      style="
        max-width: var(--section-text-width);
        text-align: {{ section.settings.alignment }};
        margin: 0 auto;
      "
    >
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="rich-text__heading"
              style="
                font-size: {{ block.settings.size }}px;
                color: {{ block.settings.color }};
                margin-top: {{ block.settings.margin_top }}px;
                margin-bottom: {{ block.settings.margin_bottom }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | escape }}
            </h2>

          {%- when 'text' -%}
            <div
              class="rich-text__text rte"
              style="
                font-size: {{ block.settings.size }}px;
                margin-top: {{ block.settings.margin_top }}px;
                margin-bottom: {{ block.settings.margin_bottom }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>

          {%- when 'button' -%}
            {%- if block.settings.label != blank -%}
              <div
                style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                {{ block.shopify_attributes }}
              >
                <a
                  href="{{ block.settings.link }}"
                  class="rich-text__button button button--{{ block.settings.style }}"
                  {% if block.settings.link == blank %}aria-disabled="true"{% endif %}
                >
                  {{ block.settings.label | escape }}
                </a>
              </div>
            {%- endif -%}

          {%- when 'spacer' -%}
            <div
              class="rich-text__spacer"
              style="height: {{ block.settings.height }}px; margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
              {{ block.shopify_attributes }}
              aria-hidden="true"
            ></div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .rich-text__heading {
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .rich-text__text {
    opacity: 0.75;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .rich-text__text p {
    margin: 0 0 1em;
  }

  #shopify-section-{{ section.id }} .rich-text__text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .rich-text__button {
    display: inline-block;
    padding: 14px 36px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .rich-text__button.button--primary {
    background-color: var(--color-accent, #D4A843);
    color: #0a0a0a;
    border: none;
  }

  #shopify-section-{{ section.id }} .rich-text__button.button--secondary {
    background: transparent;
    color: rgb(var(--color-foreground));
    border: 1px solid rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .rich-text__button.button--link {
    background: transparent;
    color: var(--color-accent, #D4A843);
    border: none;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .rich-text__button:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .rich-text__button:focus-visible {
    outline: 2px solid var(--color-accent, #D4A843);
    outline-offset: 3px;
  }

  #shopify-section-{{ section.id }} .rich-text__button:active {
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .rich-text__spacer {
    display: block;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .rich-text__heading {
      font-size: calc(var(--section-heading-size) * 0.7) !important;
    }

    #shopify-section-{{ section.id }} .rich-text__container {
      max-width: 100% !important;
      padding: 0 4px;
    }
  }
</style>

