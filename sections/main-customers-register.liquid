{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" style="background-color: #0a0a0a; color: #FFFFFF;">
  <div style="max-width: 440px; margin: 0 auto; padding: 0 20px;">
    <h1 style="margin: 0 0 32px 0; font-size: 1.75rem; font-weight: 700; color: #FFFFFF; text-align: center;">
      {{ section.settings.heading }}
    </h1>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div style="padding: 12px; margin-bottom: 20px; background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.3); border-radius: 8px; color: #fca5a5; font-size: 0.85rem;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
        <div>
          <label for="register-first-name" style="display: block; margin-bottom: 6px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">Ad</label>
          <input
            type="text"
            name="customer[first_name]"
            id="register-first-name"
            autocomplete="given-name"
            required
            style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #FFFFFF; font-size: 0.95rem; outline: none; box-sizing: border-box;"
          >
        </div>
        <div>
          <label for="register-last-name" style="display: block; margin-bottom: 6px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">Soyad</label>
          <input
            type="text"
            name="customer[last_name]"
            id="register-last-name"
            autocomplete="family-name"
            required
            style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #FFFFFF; font-size: 0.95rem; outline: none; box-sizing: border-box;"
          >
        </div>
      </div>

      <div style="margin-bottom: 16px;">
        <label for="register-email" style="display: block; margin-bottom: 6px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">E-posta</label>
        <input
          type="email"
          name="customer[email]"
          id="register-email"
          autocomplete="email"
          required
          style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #FFFFFF; font-size: 0.95rem; outline: none; box-sizing: border-box;"
        >
      </div>

      <div style="margin-bottom: 24px;">
        <label for="register-password" style="display: block; margin-bottom: 6px; font-size: 0.85rem; color: rgba(255,255,255,0.6);">Şifre</label>
        <input
          type="password"
          name="customer[password]"
          id="register-password"
          autocomplete="new-password"
          required
          style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #FFFFFF; font-size: 0.95rem; outline: none; box-sizing: border-box;"
        >
      </div>

      <button type="submit" style="width: 100%; padding: 14px; background: #FFFFFF; color: #0a0a0a; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s;">
        Kayıt Ol
      </button>

      <p style="margin: 20px 0 0; text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5);">
        Zaten hesabınız var mı?
        <a href="{{ routes.account_login_url }}" style="color: #FFFFFF; text-decoration: none; font-weight: 500;">Giriş Yap</a>
      </p>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Müşteri Kayıt",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Hesap Oluştur",
      "label": "Başlık"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "background-1",
        "options": [
          { "value": "background-1", "label": "Arka Plan 1" },
          { "value": "background-2", "label": "Arka Plan 2" },
          { "value": "accent-1", "label": "Vurgu 1" },
          { "value": "accent-2", "label": "Vurgu 2" },
          { "value": "inverse", "label": "Ters" },
          { "value": "custom", "label": "Özel" }
        ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Üst boşluk"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px",
      "label": "Alt boşluk"
    }
  ]
}
{% endschema %}
