{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;

    --section-columns-desktop: {{ section.settings.columns_desktop }};
    --section-columns-mobile: {{ section.settings.columns_mobile }};
  }

  #shopify-section-{{ section.id }} .featured-collection__heading {
    font-size: {{ section.settings.heading_size }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="featured-collection__header">
        <h2 class="featured-collection__heading">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.settings.collection != blank -%}
      {%- assign collection = section.settings.collection -%}
      {%- assign products_to_show = section.settings.products_to_show -%}

      <ul
        class="featured-collection__grid"
        role="list"
        aria-label="{{ section.settings.heading | escape }}"
      >
        {%- for product in collection.products limit: products_to_show -%}
          <li class="featured-collection__item">
            {% render 'card-product',
              product: product,
              show_vendor: section.settings.show_vendor,
              show_price: section.settings.show_price,
              show_rating: section.settings.show_rating,
              show_quick_add: section.settings.show_quick_add,
              image_ratio: section.settings.image_ratio
            %}
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.view_all_button and collection.all_products_count > products_to_show -%}
        <div class="featured-collection__view-all">
          <a
            href="{{ collection.url }}"
            class="featured-collection__view-all-btn button button--secondary"
            aria-label="{{ section.settings.view_all_text | escape }}"
          >
            {{ section.settings.view_all_text | escape }}
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="featured-collection__placeholder">
        <p>{{ 'sections.featured_collection.no_collection' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .featured-collection__header {
    text-align: center;
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .featured-collection__heading {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--section-columns-desktop, 4), 1fr);
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .featured-collection__item {
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .featured-collection__view-all {
    text-align: center;
    margin-top: 40px;
  }

  #shopify-section-{{ section.id }} .featured-collection__view-all-btn {
    display: inline-block;
    padding: 14px 40px;
    border: 1px solid rgb(var(--color-foreground));
    color: rgb(var(--color-foreground));
    background: transparent;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background-color 0.3s ease, color 0.3s ease;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .featured-collection__view-all-btn:hover {
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .featured-collection__view-all-btn:focus-visible {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 3px;
  }

  #shopify-section-{{ section.id }} .featured-collection__placeholder {
    text-align: center;
    padding: 60px 20px;
    color: rgb(var(--color-foreground));
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .featured-collection__grid {
      grid-template-columns: repeat(var(--section-columns-mobile, 2), 1fr);
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .featured-collection__heading {
      font-size: calc(var(--section-heading-size, 36) * 0.7px);
    }
  }
</style>

{% schema %}
{
  "name": "Oene Cikarilan Koleksiyon",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Baslik",
      "default": "One Cikan Urunler"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Baslik Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Koleksiyon"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Gosterilecek Urun Sayisi",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Masaustu Sutun Sayisi",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobil Sutun Sayisi",
      "options": [
        { "value": "1", "label": "1 Sutun" },
        { "value": "2", "label": "2 Sutun" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Markayi Goster",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Fiyati Goster",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Degerlendirmeyi Goster",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Hizli Ekle Butonunu Goster",
      "default": false
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Gorsel Orani",
      "options": [
        { "value": "adapt", "label": "Gorsele Uyarla" },
        { "value": "portrait", "label": "Portre (2:3)" },
        { "value": "square", "label": "Kare (1:1)" },
        { "value": "landscape", "label": "Yatay (3:2)" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "view_all_button",
      "label": "Tumunu Gor Butonu",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Tumunu Gor Butonu Metni",
      "default": "Tumunu Gor"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Ust Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "One Cikarilan Koleksiyon"
    }
  ]
}
{% endschema %}
