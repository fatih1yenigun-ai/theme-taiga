{%- style -%}
  .icons-bar-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }};
    --padding-bottom: {{ section.settings.padding_bottom }};
    --icon-size: {{ section.settings.icon_size }}px;
    --icon-gap: {{ section.settings.gap }}px;
    --label-size: {{ section.settings.label_size | divided_by: 10.0 }}rem;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section class="icons-bar icons-bar-{{ section.id }} section-padding color-{{ section.settings.color_scheme }}"
  style="border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }}; border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h3 class="{{ section.settings.heading_size }}" style="text-align: center; margin-bottom: 2rem; color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h3>
    {%- endif -%}

    <div class="icons-bar__grid" style="display: flex; justify-content: {{ section.settings.alignment }}; gap: var(--icon-gap); flex-wrap: wrap;">
      {%- for block in section.blocks -%}
        <div class="icons-bar__item" style="display: flex; flex-direction: {{ section.settings.layout }}; align-items: center; gap: 0.8rem; text-align: center;" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_image != blank -%}
            <img
              src="{{ block.settings.icon_image | image_url: width: 96 }}"
              alt="{{ block.settings.label | escape }}"
              width="{{ section.settings.icon_size }}"
              height="{{ section.settings.icon_size }}"
              style="width: var(--icon-size); height: var(--icon-size); object-fit: contain;"
              loading="lazy"
            >
          {%- endif -%}
          <div>
            {%- if block.settings.label != blank -%}
              <span style="font-size: var(--label-size); font-weight: {{ section.settings.label_weight }}; color: {{ section.settings.label_color }}; display: block;">
                {{ block.settings.label }}
              </span>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <span style="font-size: {{ section.settings.desc_size | divided_by: 10.0 }}rem; color: {{ section.settings.desc_color }}; display: block; margin-top: 0.2rem;">
                {{ block.settings.description }}
              </span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ürün İkon Çubuğu",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "İçerik"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Başlık boyutu",
      "default": "h4",
      "options": [
        { "value": "h3", "label": "Büyük" },
        { "value": "h4", "label": "Orta" },
        { "value": "h5", "label": "Küçük" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Başlık rengi",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "İkon ayarları"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px",
      "label": "İkon boyutu"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 12,
      "max": 64,
      "step": 4,
      "default": 48,
      "unit": "px",
      "label": "Öğeler arası boşluk"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Düzen yönü",
      "default": "column",
      "options": [
        { "value": "column", "label": "Dikey (ikon üstte)" },
        { "value": "row", "label": "Yatay (ikon solda)" }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Hizalama",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Sol" },
        { "value": "center", "label": "Orta" },
        { "value": "space-between", "label": "Dağıtılmış" },
        { "value": "space-around", "label": "Eşit aralıklı" }
      ]
    },
    {
      "type": "header",
      "content": "Etiket ayarları"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px",
      "label": "Etiket boyutu"
    },
    {
      "type": "range",
      "id": "label_weight",
      "min": 400,
      "max": 700,
      "step": 100,
      "default": 500,
      "label": "Etiket kalınlığı"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Etiket rengi",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 10,
      "max": 14,
      "step": 1,
      "default": 11,
      "unit": "px",
      "label": "Açıklama boyutu"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Açıklama rengi",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Renk ve kenarlık"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-2"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#141414",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 3,
      "step": 1,
      "default": 1,
      "unit": "px",
      "label": "Kenarlık kalınlığı"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Kenarlık rengi",
      "default": "#2a2a2a"
    },
    {
      "type": "header",
      "content": "Boşluk"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px",
      "label": "Üst dolgu"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px",
      "label": "Alt dolgu"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "İkon",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "İkon görseli (SVG/PNG/JPG)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiket",
          "default": "Doğal İçerik"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Açıklama"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Bağlantı"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ürün İkon Çubuğu",
      "blocks": [
        { "type": "icon", "settings": { "label": "Doğal İçerik" } },
        { "type": "icon", "settings": { "label": "Hızlı Kargo" } },
        { "type": "icon", "settings": { "label": "Kolay İade" } },
        { "type": "icon", "settings": { "label": "Güvenli Ödeme" } }
      ]
    }
  ]
}
{% endschema %}
