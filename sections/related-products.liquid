{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-bg-color: {{ section.settings.bg_color }};
    --section-heading-size: {{ section.settings.heading_size }}px;
    --section-columns: {{ section.settings.columns }};
  }
{%- endstyle -%}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
  style="background-color: var(--section-bg-color);"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="related-products__heading" style="font-size: var(--section-heading-size);">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- assign current_product = product -%}
    {%- assign related_collection = product.collections.first -%}

    {%- if related_collection != blank -%}
      {%- assign products_to_show = section.settings.products_to_show -%}

      <ul class="related-products__grid" role="list" aria-label="{{ section.settings.heading | escape }}">
        {%- assign shown_count = 0 -%}
        {%- for related_product in related_collection.products -%}
          {%- if related_product.id != current_product.id and shown_count < products_to_show -%}
            <li class="related-products__item">
              {% render 'card-product',
                product: related_product,
                show_vendor: section.settings.show_vendor,
                show_price: section.settings.show_price
              %}
            </li>
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if shown_count == 0 -%}
        <p class="related-products__empty">
          Ilgili urun bulunamadi.
        </p>
      {%- endif -%}
    {%- else -%}
      {%- if recommendations.performed -%}
        {%- if recommendations.products_count > 0 -%}
          <ul class="related-products__grid" role="list" aria-label="{{ section.settings.heading | escape }}">
            {%- for related_product in recommendations.products limit: section.settings.products_to_show -%}
              <li class="related-products__item">
                {% render 'card-product',
                  product: related_product,
                  show_vendor: section.settings.show_vendor,
                  show_price: section.settings.show_price
                %}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .related-products__heading {
    color: var(--color-foreground, #FFFFFF);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    text-align: center;
    margin: 0 0 40px;
  }

  #shopify-section-{{ section.id }} .related-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--section-columns, 4), 1fr);
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .related-products__item {
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .related-products__empty {
    text-align: center;
    color: var(--color-foreground, #FFFFFF);
    opacity: 0.5;
    font-size: 15px;
    padding: 40px 0;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .related-products__heading {
      font-size: calc(var(--section-heading-size) * 0.7) !important;
      margin-bottom: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Ilgili Urunler",
  "tag": "section",
  "class": "section-related-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Baslik",
      "default": "Bunlari da Begenebilirsiniz"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Baslik Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Gosterilecek Urun Sayisi",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Sutun Sayisi",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Markayi Goster",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Fiyati Goster",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Semasi",
      "options": [
        { "value": "scheme-1", "label": "Sema 1" },
        { "value": "scheme-2", "label": "Sema 2" },
        { "value": "scheme-3", "label": "Sema 3" },
        { "value": "inverse", "label": "Ters" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arka Plan Rengi",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Ust Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Bosluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Ilgili Urunler"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
