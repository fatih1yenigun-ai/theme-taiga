{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --section-min-height: {{ section.settings.min_height }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="fullbleed-video">
    <div class="fullbleed-video__media">
      {%- if section.settings.video_url != blank -%}
        {{ section.settings.video_url | video_tag:
          autoplay: true,
          muted: true,
          loop: true,
          playsinline: true,
          class: 'fullbleed-video__video'
        }}
      {%- else -%}
        <div class="fullbleed-video__placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      <div class="fullbleed-video__overlay" aria-hidden="true"></div>
    </div>

    <div class="fullbleed-video__content">
      <div class="page-width">
        {%- if section.settings.heading != blank -%}
          <h2 class="fullbleed-video__heading">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="fullbleed-video__subheading">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            class="fullbleed-video__button"
            {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %}
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .fullbleed-video {
    position: relative;
    min-height: var(--section-min-height, 600px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__placeholder {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__placeholder svg {
    width: 30%;
    opacity: 0.15;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, var(--section-overlay-opacity, 0.5)),
      rgba(0, 0, 0, calc(var(--section-overlay-opacity, 0.5) * 0.3))
    );
  }

  #shopify-section-{{ section.id }} .fullbleed-video__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 60px 0;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__heading {
    color: #FFFFFF;
    font-size: 56px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    text-transform: uppercase;
    margin: 0 0 16px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__subheading {
    color: rgba(255, 255, 255, 0.8);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 32px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__button {
    display: inline-block;
    padding: 16px 40px;
    background: #FFFFFF;
    color: #0a0a0a;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__button:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .fullbleed-video__button:active {
    transform: translateY(0);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .fullbleed-video {
      min-height: 400px;
    }

    #shopify-section-{{ section.id }} .fullbleed-video__heading {
      font-size: 32px;
    }

    #shopify-section-{{ section.id }} .fullbleed-video__subheading {
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .fullbleed-video__button {
      padding: 14px 32px;
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .fullbleed-video__content {
      padding: 40px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Tam Ekran Video",
  "tag": "section",
  "class": "section-fullbleed-video",
  "settings": [
    {
      "type": "video",
      "id": "video_url",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Doğanın Gücünü Keşfedin"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Alt Başlık",
      "default": "Vahşi doğadan ilham alan, dayanıklı ve güvenilir ürünler"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Buton Metni",
      "default": "Koleksiyonu Keşfet"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Buton Bağlantısı"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Karartma Oranı",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Yükseklik",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#4A7C59",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst Boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Tam Ekran Video"
    }
  ]
}
{% endschema %}
