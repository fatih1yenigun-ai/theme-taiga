{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-heading-size: {{ section.settings.heading_size }}px;
    --section-divider-color: {{ section.settings.divider_color }};
    --section-icon-size: {{ section.settings.icon_size }}px;
  }
{%- endstyle -%}

{% render 'section-custom-scheme-style', section: section %}

<section
  id="shopify-section-{{ section.id }}"
  class="section-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="prestige-cred__heading" style="font-size: var(--section-heading-size);">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="prestige-cred__row" role="list">
        {%- for block in section.blocks -%}
          <div class="prestige-cred__item" role="listitem" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="prestige-cred__icon">
                <img
                  src="{{ block.settings.icon | image_url: width: 120 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="{{ section.settings.icon_size }}"
                  height="{{ section.settings.icon_size }}"
                  loading="lazy"
                >
              </div>
            {%- else -%}
              <div class="prestige-cred__icon prestige-cred__icon--placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="prestige-cred__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.subtitle != blank -%}
              <p class="prestige-cred__subtitle">{{ block.settings.subtitle | escape }}</p>
            {%- endif -%}
          </div>

          {%- unless forloop.last -%}
            <div class="prestige-cred__divider" aria-hidden="true"></div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .section-padding {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #shopify-section-{{ section.id }} .prestige-cred__heading {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    text-align: center;
    margin: 0 0 48px;
  }

  #shopify-section-{{ section.id }} .prestige-cred__row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .prestige-cred__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 32px;
    flex: 0 1 auto;
    min-width: 140px;
  }

  #shopify-section-{{ section.id }} .prestige-cred__icon {
    width: var(--section-icon-size);
    height: var(--section-icon-size);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .prestige-cred__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .prestige-cred__icon--placeholder {
    opacity: 0.3;
  }

  #shopify-section-{{ section.id }} .prestige-cred__icon--placeholder svg {
    width: 60%;
  }

  #shopify-section-{{ section.id }} .prestige-cred__title {
    color: rgb(var(--color-foreground));
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }

  #shopify-section-{{ section.id }} .prestige-cred__subtitle {
    color: rgb(var(--color-foreground));
    opacity: 0.6;
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .prestige-cred__divider {
    width: 1px;
    height: 48px;
    background: var(--section-divider-color, rgba(212, 168, 67, 0.25));
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .prestige-cred__row {
      flex-direction: column;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .prestige-cred__divider {
      width: 48px;
      height: 1px;
    }

    #shopify-section-{{ section.id }} .prestige-cred__item {
      padding: 16px 24px;
    }

    #shopify-section-{{ section.id }} .prestige-cred__heading {
      font-size: calc(var(--section-heading-size) * 0.7) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Prestij Sertifikaları",
  "tag": "section",
  "class": "section-prestige-credentials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Güvenilir Sertifikalar"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Başlık Boyutu",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "İkon Boyutu",
      "min": 32,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Ayırıcı Çizgi Rengi",
      "default": "rgba(212, 168, 67, 0.25)"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Renk Şeması",
      "options": [
        { "value": "background-1", "label": "Arka Plan 1" },
        { "value": "background-2", "label": "Arka Plan 2" },
        { "value": "accent-1", "label": "Vurgu 1" },
        { "value": "accent-2", "label": "Vurgu 2" },
        { "value": "inverse", "label": "Ters" },
        { "value": "custom", "label": "Özel" }
      ],
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Özel Arka Plan Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Özel Metin Rengi",
      "default": "#FFFFFF",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_accent_color",
      "label": "Özel Vurgu Rengi",
      "default": "#D4A843",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "color",
      "id": "custom_button_label_color",
      "label": "Özel Buton Metin Rengi",
      "default": "#0a0a0a",
      "info": "Yalnızca 'Özel' renk şeması seçildiğinde etkindir"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst Boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt Boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Sertifika",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "İkon Görseli"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Başlık",
          "default": "Dermatolog Onaylı"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Alt Başlık",
          "default": "Klinik testlerden geçmiştir"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Prestij Sertifikaları",
      "blocks": [
        { "type": "credential", "settings": { "title": "Dermatolog Onaylı", "subtitle": "Klinik testlerden geçmiştir" } },
        { "type": "credential", "settings": { "title": "ISO Sertifikalı", "subtitle": "Uluslararası kalite standardı" } },
        { "type": "credential", "settings": { "title": "Ödüllü Formül", "subtitle": "2024 En İyi Ürün Ödülü" } },
        { "type": "credential", "settings": { "title": "Doğal İçerik", "subtitle": "%95 doğal kaynaklı bileşenler" } }
      ]
    }
  ]
}
{% endschema %}
